# Public browser-safe Supabase credentials
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
PUBLIC_SITE_URL=http://localhost:4321

# Supabase Edge Function secrets, set in Supabase dashboard/CLI, never expose to browser
# Local `supabase functions serve` can also use Supabase's built-in SUPABASE_* names.
BRAGA_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
BRAGA_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
BRAGA_SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
INVITE_REDIRECT_URL=http://localhost:4321/auth/confirm
COMMUNITY_NAME="Your Local AI Community"
# Optional: notify an organizer after a bug report is stored.
RESEND_API_KEY=YOUR_RESEND_API_KEY
BUG_REPORT_NOTIFICATION_EMAIL=organizer@example.com
BUG_REPORT_FROM_EMAIL="Your Community <noreply@your-verified-domain.example>"
# Must match an active row in public.invites for account creation from Posts.
IDEA_SIGNUP_INVITE_CODE=local-development-only

---
import { communityConfig } from '../config/community';
import BugReportDialog from './bug-reports/BugReportDialog';
---
<footer class="border-t border-white/10 py-10">
  <div class="mx-auto flex max-w-6xl flex-col gap-5 px-4 text-sm text-braga-200 sm:px-6 md:flex-row md:items-center md:justify-between lg:px-8">
    <p>
      This site is powered by
      <a href={communityConfig.githubUrl} target="_blank" rel="noreferrer noopener" class="mx-1 font-semibold text-limewash underline decoration-limewash/70 underline-offset-4 transition-colors hover:text-white hover:decoration-white">Local Community Platform</a>,
      an open-source platform for managing local communities.
      <a href={communityConfig.githubUrl} target="_blank" rel="noreferrer noopener" aria-label="View Local Community Platform on GitHub" class="ml-1 text-limewash transition-colors hover:text-white">↗</a>
    </p>
    <nav class="flex flex-wrap gap-5" aria-label="Footer navigation">
      <a href="/ideas" class="hover:text-limewash">Posts</a>
      <a href="/events" class="hover:text-limewash">Events</a>
      <a href="/members" class="hover:text-limewash">Members</a>
      <BugReportDialog client:load />
    </nav>
  </div>
</footer>

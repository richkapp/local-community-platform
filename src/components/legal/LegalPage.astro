---
interface Props {
  eyebrow: string;
  title: string;
  summary: string;
  lastUpdated: string;
}

const { eyebrow, title, summary, lastUpdated } = Astro.props;
---
<article class="mx-auto max-w-4xl px-4 py-14 sm:px-6 lg:px-8 lg:py-20">
  <header class="max-w-3xl">
    <p class="text-sm font-bold uppercase tracking-[0.2em] text-limewash">{eyebrow}</p>
    <h1 class="mt-4 text-4xl font-black tracking-tight text-white sm:text-5xl">{title}</h1>
    <p class="mt-5 text-lg leading-8 text-braga-100">{summary}</p>
    <p class="mt-4 text-sm text-braga-300">Last updated: {lastUpdated}</p>
  </header>

  <div class="legal-copy mt-12">
    <slot />
  </div>
</article>

<style>
  .legal-copy :global(section) {
    margin-top: 2.5rem;
  }

  .legal-copy :global(section:first-child) {
    margin-top: 0;
  }

  .legal-copy :global(h2) {
    color: white;
    font-size: 1.4rem;
    font-weight: 800;
    line-height: 1.3;
  }

  .legal-copy :global(h3) {
    color: white;
    font-size: 1rem;
    font-weight: 750;
    margin-top: 1.5rem;
  }

  .legal-copy :global(p),
  .legal-copy :global(li) {
    color: rgb(203 213 225);
    line-height: 1.8;
  }

  .legal-copy :global(p),
  .legal-copy :global(ul),
  .legal-copy :global(ol) {
    margin-top: 0.9rem;
  }

  .legal-copy :global(ul),
  .legal-copy :global(ol) {
    padding-left: 1.35rem;
  }

  .legal-copy :global(ul) {
    list-style: disc;
  }

  .legal-copy :global(ol) {
    list-style: decimal;
  }

  .legal-copy :global(li + li) {
    margin-top: 0.55rem;
  }

  .legal-copy :global(a) {
    color: #c8ff5a;
    font-weight: 650;
    text-decoration: underline;
    text-decoration-color: rgb(200 255 90 / 0.55);
    text-underline-offset: 0.2em;
  }

  .legal-copy :global(a:hover) {
    color: white;
    text-decoration-color: white;
  }

  .legal-copy :global(strong) {
    color: white;
    font-weight: 750;
  }

  .legal-copy :global(.legal-note) {
    border: 1px solid rgb(200 255 90 / 0.25);
    border-radius: 1rem;
    background: rgb(200 255 90 / 0.06);
    padding: 1rem 1.1rem;
  }
</style>

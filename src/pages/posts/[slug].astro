---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IdeaDetail from '../../components/ideas/IdeaDetail';
import { communityPageTitle } from '../../config/community';
import { publicRecordExists } from '../../lib/public-server';

export const prerender = false;

const slug = Astro.params.slug ?? '';
const exists = /^[a-z0-9][a-z0-9-]{2,159}$/.test(slug)
  ? await publicRecordExists('ideas', 'slug', slug)
  : false;
if (exists === false) Astro.response.status = 404;
---
<BaseLayout title={communityPageTitle('Post')}>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6 lg:px-8">
    <IdeaDetail slug={slug} client:load />
  </section>
</BaseLayout>

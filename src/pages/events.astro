---
import BaseLayout from '../layouts/BaseLayout.astro';
import EventList from '../components/events/EventList';
---
<BaseLayout title="Events · Braga AI Builders">
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="text-4xl font-black text-white">Monthly events</h1>
    <p class="mt-4 text-slate-300">Meetups, build nights, and workshops for the Braga AI Builders community.</p>
    <div class="mt-8">
      <EventList client:load />
    </div>
  </section>
</BaseLayout>

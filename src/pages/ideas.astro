---
import BaseLayout from '../layouts/BaseLayout.astro';
import IdeaComposer from '../components/ideas/IdeaComposer';
import IdeaFeed from '../components/ideas/IdeaFeed';
---
<BaseLayout title="Ideas · Braga AI Builders">
  <section class="mx-auto grid max-w-7xl gap-8 px-4 py-16 sm:px-6 lg:grid-cols-[380px_1fr] lg:px-8">
    <aside>
      <IdeaComposer client:load />
    </aside>
    <div>
      <h1 class="text-4xl font-black text-white">Activity ideas</h1>
      <p class="mt-4 text-slate-300">Suggest what the group should build, learn, or discuss next. Upvotes only.</p>
      <div class="mt-8">
        <IdeaFeed client:load />
      </div>
    </div>
  </section>
</BaseLayout>

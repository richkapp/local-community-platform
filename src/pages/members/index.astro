---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MemberDirectory from '../../components/profile/MemberDirectory';
import { communityPageTitle } from '../../config/community';
---
<BaseLayout title={communityPageTitle('Members')}>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="text-4xl font-black text-white">Members</h1>
    <p class="mt-4 text-slate-300">Public profiles from builders who opted into the directory.</p>
    <div class="mt-8">
      <MemberDirectory client:load />
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MemberDirectory from '../../components/profile/MemberDirectory';
---
<BaseLayout title="Member profile · Braga AI Builders">
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="text-4xl font-black text-white">Member profile</h1>
    <p class="mt-4 text-slate-300">Direct profile pages will be expanded after the first member import. For now, browse the member directory.</p>
    <div class="mt-8">
      <MemberDirectory client:load />
    </div>
  </section>
</BaseLayout>

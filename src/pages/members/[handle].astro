---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MemberProfile from '../../components/profile/MemberProfile';
import { communityPageTitle } from '../../config/community';
import { publicRecordExists } from '../../lib/public-server';

export const prerender = false;

const handle = Astro.params.handle ?? '';
const exists = /^[a-z0-9][a-z0-9-]{2,39}$/.test(handle)
  ? await publicRecordExists('public_profiles', 'handle', handle)
  : false;
if (exists === false) Astro.response.status = 404;
---
<BaseLayout title={communityPageTitle('Member')}>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <a class="text-sm font-semibold text-limewash" href="/members">← All members</a>
    <div class="mt-6">
      <MemberProfile handle={handle} client:load />
    </div>
  </section>
</BaseLayout>
